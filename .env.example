# Database
# For dev: SQLite (default, zero-infra)
DATABASE_URL="file:./dev.db"
# For prod: switch provider to "postgresql" in prisma/schema.prisma and use:
# DATABASE_URL="postgresql://demands:demands@localhost:5432/demands?schema=public"

# JWT
JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="12h"

# CORS
CORS_ORIGIN="http://localhost:4200"

# HTTP
PORT=3000
