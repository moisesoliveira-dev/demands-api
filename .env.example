# ── Database ─────────────────────────────────────────────────────────────────
# No Docker Compose isto é sobrescrito automaticamente para apontar para o
# container `db` (pgvector). Esta linha só vale ao rodar a API fora do Docker.
DATABASE_URL="postgresql://demands:demands@localhost:5432/demands?schema=public"

# ── JWT ──────────────────────────────────────────────────────────────────────
# TROQUE EM PRODUÇÃO. Gere com: openssl rand -base64 48
JWT_SECRET="dev-secret-change-me"
# Aceita "12h", "7d", "30m", número em segundos, etc.
JWT_EXPIRES_IN="12h"

# ── CORS ─────────────────────────────────────────────────────────────────────
# Lista separada por vírgula. "*" é aceito mas desabilita credentials.
CORS_ORIGIN="http://localhost:8181"

# ── HTTP ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── IA (Agno / AgentOS) ──────────────────────────────────────────────────────
# No Docker Compose isto é sobrescrito para http://ai:7777.
DEMANDS_AI_URL="http://localhost:7777"

# ── Admin inicial (só usado no primeiro start) ───────────────────────────────
# ADMIN_NOME="Administrador"
# ADMIN_EMAIL="admin@local.dev"
# ADMIN_SENHA="Admin@1234"

# ── Banco corporativo dbacesso (somente leitura) ─────────────────────────────
# Credenciais do ambiente de teste (147.1.0.100).
# NUNCA execute DDL/DML neste banco — apenas SELECTs.
DATABASE_ACESSO_HOST=147.1.0.100
DATABASE_ACESSO_PORT=3308
DATABASE_ACESSO_USER=root
DATABASE_ACESSO_PASSWORD=root
DATABASE_ACESSO_NAME=dbacesso

# ID do sistema cadastrado na tabela `sistemas` do dbacesso.
# Obrigatório — o login falha se não estiver definido.
ID_SISTEMA=45
