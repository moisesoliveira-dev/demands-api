# ── Database ─────────────────────────────────────────────────────────────────

DATABASE_URL="postgresql://demands:demands@localhost:5432/demands?schema=public"

# Memória (perfil "memory" do docker-compose — mesmo Postgres, porta diferente)
# DATABASE_URL="postgresql://demands:demands@localhost:5433/demands?schema=public"

# Supabase (cole a connection string da dashboard → Settings → Database)
# DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=public"

# ── JWT ──────────────────────────────────────────────────────────────────────
# TROQUE EM PRODUÇÃO. Gere com: openssl rand -base64 48
JWT_SECRET="dev-secret-change-me"
# Aceita "12h", "7d", "30m", número em segundos, etc.
JWT_EXPIRES_IN="12h"

# ── CORS ─────────────────────────────────────────────────────────────────────
# Lista separada por vírgula. "*" é aceito mas desabilita credentials.
CORS_ORIGIN="http://localhost:4200"

# ── HTTP ─────────────────────────────────────────────────────────────────────
PORT=3000
# Prefixo global. O frontend deve incluir "/api" em apiUrl.
# (atualmente fixo no main.ts; exposto aqui para futuro)
# API_PREFIX="api"

# ── IA (Agno / AgentOS) ───────────────────────────────────────────────────────
# URL interna do serviço demands-ai. O NestJS proxia /api/ai/* para cá.
DEMANDS_AI_URL="http://localhost:7777"

# ── Logs ─────────────────────────────────────────────────────────────────────
# log levels: error|warn|log|debug|verbose (separados por vírgula)
# LOG_LEVEL="log,error,warn"
