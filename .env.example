# ── Database ─────────────────────────────────────────────────────────────────
# Dev (default): SQLite, zero-infra
DATABASE_URL="file:./dev.db"
# Prod: PostgreSQL (lembre de trocar provider em prisma/schema.prisma)
# DATABASE_URL="postgresql://demands:demands@localhost:5432/demands?schema=public"

# ── JWT ──────────────────────────────────────────────────────────────────────
# TROQUE EM PRODUÇÃO. Gere com: openssl rand -base64 48
JWT_SECRET="dev-secret-change-me"
# Aceita "12h", "7d", "30m", número em segundos, etc.
JWT_EXPIRES_IN="12h"

# ── CORS ─────────────────────────────────────────────────────────────────────
# Lista separada por vírgula. "*" é aceito mas desabilita credentials.
CORS_ORIGIN="http://localhost:4200"

# ── HTTP ─────────────────────────────────────────────────────────────────────
PORT=3000
# Prefixo global. O frontend deve incluir "/api" em apiUrl.
# (atualmente fixo no main.ts; exposto aqui para futuro)
# API_PREFIX="api"

# ── Logs ─────────────────────────────────────────────────────────────────────
# log levels: error|warn|log|debug|verbose (separados por vírgula)
# LOG_LEVEL="log,error,warn"
