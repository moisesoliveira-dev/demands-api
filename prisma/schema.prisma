// Prisma schema for demands-api — PostgreSQL (works with local Postgres and Supabase).
// O modo "memory" usa um Postgres efêmero (tmpfs) via docker-compose, então o schema é único.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: enum-like fields são validados na camada de aplicação (ver src/common/permissions.ts).
// customPermissions, draft e messages são armazenados como JSON em string para manter
// compatibilidade com o contrato da DataStore original.

model User {
  id                 String    @id @default(cuid())
  nome               String
  email              String    @unique
  senhaHash          String
  cargo              String
  setor              String
  role               String    // 'admin' | 'supervisor' | 'operador' | 'visualizador'
  customPermissions  String    @default("[]") // JSON-encoded string[]
  avatar             String?
  avatarUrl          String?
  ativo              Boolean   @default(true)
  criadoEm           DateTime  @default(now())
  ultimoAcesso       DateTime?

  sessions           ChatSession[]
  notificacoes       Notificacao[]
}

model Setor {
  id          String   @id @default(cuid())
  nome        String   @unique
  descricao   String   @default("")
  responsavel String
  ativo       Boolean  @default(true)
  criadoEm    DateTime @default(now())
}

model Demanda {
  id              String   @id @default(cuid())
  titulo          String
  descricao       String
  prioridade      Int
  status          String   // 'pendente' | 'em_andamento' | 'concluido' | 'bloqueado'
  setor           String
  responsavel     String
  criadorId       String?  // user.id (ou login dbacesso) de quem criou a demanda
  criadorNome     String?  // snapshot p/ exibição (caso criador seja excluído)
  ordem           Int      @default(0)
  motivoBloqueio  String?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  historico       HistoricoAuditoria[]
  notificacoes    Notificacao[]
  conversas       DemandaConversa[]

  @@index([status])
  @@index([setor])
  @@index([responsavel])
  @@index([criadorId])
  @@index([ordem])
}

model DemandaConversa {
  id          String   @id @default(cuid())
  demandaId   String
  autorId     String   // user.id ou login (estrável para guards)
  autorNome   String
  autorRole   String   // 'solicitante' | 'responsavel' | 'admin' | 'sistema' | 'ia'
  conteudo    String
  criadoEm    DateTime @default(now())

  demanda     Demanda  @relation(fields: [demandaId], references: [id], onDelete: Cascade)

  @@index([demandaId, criadoEm])
}

model HistoricoAuditoria {
  id          String   @id @default(cuid())
  demandaId   String
  de          String
  para        String
  responsavel String
  motivo      String?
  timestamp   DateTime @default(now())

  demanda     Demanda  @relation(fields: [demandaId], references: [id], onDelete: Cascade)

  @@index([demandaId])
}

model Notificacao {
  id          String   @id @default(cuid())
  usuarioId   String?
  demandaId   String?
  tipo        String   @default("sistema")
  titulo      String
  mensagem    String
  prioridade  Int      @default(3)
  acao        String?
  lida        Boolean  @default(false)
  timestamp   DateTime @default(now())

  usuario     User?    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  demanda     Demanda? @relation(fields: [demandaId], references: [id], onDelete: SetNull)

  @@index([usuarioId])
  @@index([timestamp])
}

model ChatSession {
  id           String   @id @default(cuid())
  usuarioId    String
  titulo       String   @default("Nova triagem")
  step         String   @default("descricao")
  status       String   @default("andamento")
  draft        String   @default("{}")  // JSON
  messages     String   @default("[]")  // JSON
  criadaEm     DateTime @default(now())
  atualizadaEm DateTime @updatedAt

  usuario      User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([atualizadaEm])
}

model AppSetting {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @default(now()) @updatedAt
  updatedBy String?

  @@map("app_settings")
}

// ============================================================================
// PLATAFORMA DE CONVERSAS (estilo WhatsApp)
// ----------------------------------------------------------------------------
// Requisito legal: tudo é PROVA. Mensagens NUNCA são deletadas fisicamente.
// - apagadoEm marca exclusão lógica (UI esconde, banco preserva).
// - hashConteudo = SHA-256(autorId|criadoEm|conteudo|anexosHashes) — qualquer
//   adulteração no banco invalida o hash, permitindo auditoria.
// - ipOrigem + userAgent capturam contexto do envio.
// - autorNomeSnapshot preserva o nome mesmo se o usuário for renomeado/excluído.
// - Anexos no MinIO usam o próprio sha256 como filename (imutável).
// ============================================================================

model Conversa {
  id                String   @id @default(cuid())
  tipo              String   // 'direto' (1:1) | 'grupo' | 'demanda'
  titulo            String?  // null em 'direto' (computado dos participantes); obrigatório em 'grupo'
  descricao         String?  // descrição de grupo
  avatarUrl         String?
  demandaId         String?  @unique  // se tipo='demanda', referencia Demanda
  criadorId         String   // usuário que criou
  criadorNome       String   // snapshot
  criadoEm          DateTime @default(now())
  ultimaMensagemEm  DateTime @default(now())  // para ordenação estilo WhatsApp
  arquivada         Boolean  @default(false)

  participantes     ConversaParticipante[]
  mensagens         Mensagem[]

  @@index([ultimaMensagemEm])
  @@index([tipo])
  @@index([demandaId])
  @@index([criadorId])
}

model ConversaParticipante {
  id              String    @id @default(cuid())
  conversaId      String
  usuarioId       String
  usuarioNome     String    // snapshot
  papel           String    @default("membro")  // 'dono' | 'admin' | 'membro'
  entrouEm        DateTime  @default(now())
  saiuEm          DateTime?  // null = ativo
  ultimaLeituraEm DateTime?  // para contagem de não lidas
  silenciado      Boolean   @default(false)

  conversa        Conversa  @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  @@unique([conversaId, usuarioId])
  @@index([usuarioId])
  @@index([conversaId])
}

model Mensagem {
  id              String    @id @default(cuid())
  conversaId      String
  autorId         String
  autorNome       String    // snapshot imutável
  tipo            String    @default("texto")  // 'texto' | 'imagem' | 'video' | 'sistema'
  conteudo        String    @default("")  // texto ou legenda do anexo
  // — auditoria / provas legais —
  hashConteudo    String    // SHA-256(autorId|criadoEm|conteudo|hashesAnexos)
  ipOrigem        String?
  userAgent       String?
  // — controle de edição/exclusão (soft) —
  criadoEm        DateTime  @default(now())
  editadoEm       DateTime?
  apagadoEm       DateTime?  // soft delete — registro preservado
  // — análise IA (somente imagens) —
  analisada       Boolean   @default(false)
  analiseIA       String?   // JSON com descrição/OCR retornados pelo Vision

  conversa        Conversa  @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  anexos          MensagemAnexo[]
  leituras        MensagemLeitura[]

  @@index([conversaId, criadoEm])
  @@index([autorId])
  @@index([criadoEm])
}

model MensagemAnexo {
  id            String   @id @default(cuid())
  mensagemId    String
  tipo          String   // 'imagem' | 'video'
  nomeOriginal  String   // nome do arquivo enviado pelo usuário (para download)
  storageKey    String   // key no MinIO (== sha256 + extensão)
  mimeType      String
  bytes         Int
  sha256        String   // hash do conteúdo binário — prova de integridade
  largura       Int?
  altura        Int?
  duracaoMs     Int?     // para vídeos
  criadoEm      DateTime @default(now())

  mensagem      Mensagem @relation(fields: [mensagemId], references: [id], onDelete: Cascade)

  @@index([mensagemId])
  @@index([sha256])
}

model MensagemLeitura {
  mensagemId String
  usuarioId  String
  lidaEm     DateTime @default(now())

  mensagem   Mensagem @relation(fields: [mensagemId], references: [id], onDelete: Cascade)

  @@id([mensagemId, usuarioId])
  @@index([usuarioId])
}

