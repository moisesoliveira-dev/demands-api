// Prisma schema for demands-api — PostgreSQL (works with local Postgres and Supabase).
// O modo "memory" usa um Postgres efêmero (tmpfs) via docker-compose, então o schema é único.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: enum-like fields são validados na camada de aplicação (ver src/common/permissions.ts).
// customPermissions, draft e messages são armazenados como JSON em string para manter
// compatibilidade com o contrato da DataStore original.

model User {
  id                 String    @id @default(cuid())
  nome               String
  email              String    @unique
  senhaHash          String
  cargo              String
  setor              String
  role               String    // 'admin' | 'supervisor' | 'operador' | 'visualizador'
  customPermissions  String    @default("[]") // JSON-encoded string[]
  avatar             String?
  avatarUrl          String?
  ativo              Boolean   @default(true)
  criadoEm           DateTime  @default(now())
  ultimoAcesso       DateTime?

  sessions           ChatSession[]
  notificacoes       Notificacao[]
}

model Setor {
  id          String   @id @default(cuid())
  nome        String   @unique
  descricao   String   @default("")
  responsavel String
  ativo       Boolean  @default(true)
  criadoEm    DateTime @default(now())
}

model Demanda {
  id              String   @id @default(cuid())
  titulo          String
  descricao       String
  prioridade      Int
  status          String   // 'pendente' | 'em_andamento' | 'concluido' | 'bloqueado'
  setor           String
  responsavel     String
  ordem           Int      @default(0)
  motivoBloqueio  String?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  historico       HistoricoAuditoria[]
  notificacoes    Notificacao[]

  @@index([status])
  @@index([setor])
  @@index([responsavel])
  @@index([ordem])
}

model HistoricoAuditoria {
  id          String   @id @default(cuid())
  demandaId   String
  de          String
  para        String
  responsavel String
  motivo      String?
  timestamp   DateTime @default(now())

  demanda     Demanda  @relation(fields: [demandaId], references: [id], onDelete: Cascade)

  @@index([demandaId])
}

model Notificacao {
  id          String   @id @default(cuid())
  usuarioId   String?
  demandaId   String?
  tipo        String   @default("sistema")
  titulo      String
  mensagem    String
  prioridade  Int      @default(3)
  acao        String?
  lida        Boolean  @default(false)
  timestamp   DateTime @default(now())

  usuario     User?    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  demanda     Demanda? @relation(fields: [demandaId], references: [id], onDelete: SetNull)

  @@index([usuarioId])
  @@index([timestamp])
}

model ChatSession {
  id           String   @id @default(cuid())
  usuarioId    String
  titulo       String   @default("Nova triagem")
  step         String   @default("descricao")
  status       String   @default("andamento")
  draft        String   @default("{}")  // JSON
  messages     String   @default("[]")  // JSON
  criadaEm     DateTime @default(now())
  atualizadaEm DateTime @updatedAt

  usuario      User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([atualizadaEm])
}
